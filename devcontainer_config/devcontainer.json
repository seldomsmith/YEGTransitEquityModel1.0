{
  "name": "Transit Equity Dashboard (TED)",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "jdkDistro": "ms_openjdk"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libgdal-dev build-essential && pip install --upgrade pip && pip install -r requirements.txt",
  "remoteUser": "vscode"
}
